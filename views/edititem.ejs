<!DOCTYPE html>
<html lang="en">
<head>
    <title>TaskFlow | Edit Task</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        :root {
            --primary: #3b82f6;
            --primary-dark: #2563eb;
            --light: #f8fafc;
            --dark: #1e293b;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }
        .edit-container {
            background: white;
            border-radius: 16px;
            padding: 40px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
            max-width: 500px;
            width: 100%;
            transition: all 0.3s ease;
        }
        .edit-container:hover {
         transform: translateY(-4px);
        }
        .edit-header {
            text-align: center;
            margin-bottom: 30px;
        }
        .edit-header h1 {
            color: var(--dark);
            font-size: 2rem;
            margin-bottom: 10px;
        }
        .edit-form {
            width: 100%;
        }
        .form-group {
            margin-bottom: 25px;
        }
        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: var(--dark);
        }
        .form-control {
            width: 100%;
            padding: 15px;
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            font-size: 1rem;
            transition: border-color 0.3s ease;
        }
        .form-control:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }
        .btn-save {
            background: var(--primary);
            color: white;
            padding: 15px 30px;
            border: none;
            border-radius: 8px;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.3s ease;
            width: 100%;
            box-shadow: 0 8px 20px rgba(59,130,246,.35);
        }
        .btn-save:hover {
    background: var(--primary-dark);
    transform: translateY(-2px);
}
        .back-link {
            display: block;
            text-align: center;
            margin-top: 20px;
            color: var(--primary);
            text-decoration: none;
            font-weight: 500;
        }
        .back-link:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div class="edit-container">
        <div class="edit-header">
           <h1>✏️ Edit Task</h1>
<p style="margin-top:8px;color:#64748b;font-size:15px;">
Update your task and save changes.
</p>
        </div>
        <form action="/edit/<%= todoIdx %>" method="post" class="edit-form">
            <input type="hidden" name="_method" value="PUT">
            
            <div class="form-group">
                <label for="editTodo">Task Name</label>
                <input type="text" name="editTodo" id="editTodo" class="form-control" 
                       value="<%- todo %>" autofocus />
            </div>
            <button type="submit" class="btn-save">💾 Save Changes</button>
        </form>
        <a href="/" class="back-link">⬅ Back to Dashboard</a>
    </div>
</body>
</html>