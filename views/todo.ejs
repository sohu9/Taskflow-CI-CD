<!DOCTYPE html>
<html lang="en">
<head>
    <title>TaskFlow  application build automate </title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        :root {
            --primary: #3b82f6;
            --primary-dark: #2563eb;
            --secondary: #64748b;
            --success: #10b981;
            --warning: #f59e0b;
            --danger: #ef4444;
            --light: #f8fafc;
            --dark: #1e293b;
            --card-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        }
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
            color: var(--dark);
        }
        .container {
            max-width: 800px;
            margin: 0 auto;
            background: white;
            border-radius: 16px;
            box-shadow: var(--card-shadow);
            overflow: hidden;
        }
        .header {
            background: var(--primary);
            color: white;
            padding: 30px;
            text-align: center;
        }
        .header h1 {
            font-size: 2rem;
            font-weight: 600;
            margin-bottom: 8px;
        }
        .header p {
            opacity: 0.9;
            font-size: 1.1rem;
        }
        .tasks-container {
            padding: 30px;
        }
        .task-list {
            list-style: none;
            margin-bottom: 30px;
        }
        .task-item {
            background: var(--light);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            transition: all 0.3s ease;
            border-left: 4px solid var(--primary);
        }
        .task-item:hover {
            transform: translateY(-2px);
            box-shadow: var(--card-shadow);
        }
        .task-content {
            flex: 1;
            font-size: 1.1rem;
            font-weight: 500;
        }
        .task-actions {
            display: flex;
            gap: 12px;
        }
        .btn {
            padding: 10px 16px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
            font-size: 0.9rem;
        }
        .btn-edit {
            background: var(--warning);
            color: white;
        }
        .btn-edit:hover {
            background: #eab308;
        }
        .btn-delete {
            background: var(--danger);
            color: white;
        }
        .btn-delete:hover {
            background: #dc2626;
        }
        .add-task-form {
            background: var(--light);
            padding: 25px;
            border-radius: 12px;
        }
        .form-group {
            margin-bottom: 20px;
        }
        .form-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: var(--dark);
        }
        .form-control {
            width: 100%;
            padding: 14px;
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            font-size: 1rem;
            transition: border-color 0.3s ease;
        }
        .form-control:focus {
            outline: none;
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
        }
        .btn-primary {
            background: var(--primary);
            color: white;
            padding: 14px 28px;
            font-size: 1.1rem;
        }
        .btn-primary:hover {
            background: var(--primary-dark);
        }
        .empty-state {
            text-align: center;
            padding: 40px;
            color: var(--secondary);
        }
        .empty-state h3 {
            margin-bottom: 10px;
            font-size: 1.5rem;
        }
        @media (max-width: 600px) {
            .container {
                margin: 10px;
                border-radius: 12px;
            }
            
            .header {
                padding: 20px;
            }
            
            .tasks-container {
                padding: 20px;
            }
            
            .task-item {
                flex-direction: column;
                gap: 15px;
                text-align: center;
            }
            
            .task-actions {
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
           <h1>🚀 TaskFlow</h1>
<p>Modern Task Manager Dashboard</p>
        </div>
        <div class="tasks-container">
            <% if (todolist.length > 0) { %>
                <ul class="task-list">
                    <% todolist.forEach(function(todo, index) { %>
                    <li class="task-item">
                        <span class="task-content"><%- todo %></span>
                        <div class="task-actions">
                            <a href="/edit/<%= index %>" class="btn btn-edit">Edit</a>
                            <a href="/delete/<%= index %>" class="btn btn-delete">Delete</a>
                        </div>
                    </li>
                    <% }); %>
                </ul>
            <% } else { %>
                <div class="empty-state">
                    <h3>No tasks yet</h3>
                    <p>Start by adding your first task.</p>
                </div>
            <% } %>
            <div class="add-task-form">
                <form action="/add/" method="post">
                    <div class="form-group">
                        <label for="newtodo">Add New Task</label>
                        <input type="text" name="newtodo" id="newtodo" class="form-control" 
                               placeholder="Enter a new task..." autofocus />
                    </div>
                    <button type="submit" class="btn btn-primary">Add Task</button>
                </form>
            </div>
        </div>
    </div>
</body>
</html>

